SECRET_KEY=change-me
DEBUG=1
ALLOWED_HOSTS=127.0.0.1,localhost

# Neon Postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
NEON_WAKE_ENABLED=1
NEON_API_KEY=replace-with-neon-api-key
NEON_PROJECT_ID=replace-with-neon-project-id
NEON_ENDPOINT_ID=ep-royal-sea-adqsh3oh
NEON_WAKE_TIMEOUT=8

# Optional seed override
SEED_ADMIN_PASSWORD=replace-with-secure-admin-password

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=replace-with-cloudinary-api-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-api-secret
